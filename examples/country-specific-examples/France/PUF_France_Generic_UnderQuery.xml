<?xml version="1.0" encoding="UTF-8"?>
<!--
    PUF Invoice Response — France
    Use Case: Buyer → Seller. Invoice placed under query / in dispute (En litige).
    French CDAR status code: 207 (En litige) — maps to PUF ResponseCode "UQ" (Under Query).

    Reference invoice: PUF_France_Generic_Invoice.xml (FR-INV-2026-001)
    Sender   (Buyer):  Entreprise Client France SA — SIREN 123456789
    Receiver (Seller): TechDistrib France SARL — SIREN 987654321

    Dispute reason   : TX_TVA_ERR — incorrect VAT rate. A French reason code valid for
                       LITIGE/207 per the CDV schematron (BR-FR-CDV-CL-09/MDT-113_207).
    Clarifications   : the disputed field (BT-152, line VAT rate) carried two characteristics —
                       DIV (the current/invalid value, 10%) and DVA (the expected/valid value, 20%).
    Requested action : CNF — create a full credit note.

    Note: the data clarifications are carried in puf:StatusExtension/puf:Clarifications on the
    reason status. See status-extension.adoc for the full element list.
-->
<ApplicationResponse xmlns="urn:oasis:names:specification:ubl:schema:xsd:ApplicationResponse-2"
                     xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
                     xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2"
                     xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
                     xmlns:puf="urn:pagero:ExtensionComponent:1.0">
    <!-- Specification Identifier -->
    <cbc:CustomizationID>urn:pagero.com:puf:invoice_response:1.0</cbc:CustomizationID>
    <!-- Business process type identifier -->
    <cbc:ProfileID>urn:pagero.com:puf:invoice_response:1.0</cbc:ProfileID>
    <!-- Response identifier (max 20 characters) -->
    <cbc:ID>RESP-FR-2026-007</cbc:ID>
    <!-- Response issue date -->
    <cbc:IssueDate>2026-02-12</cbc:IssueDate>
    <!-- Response issue time (mandatory in France) -->
    <cbc:IssueTime>11:15:00</cbc:IssueTime>
    <!-- Optional freetext note -->
    <cbc:Note>Mise en litige de la facture FR-INV-2026-001 : taux de TVA erroné.</cbc:Note>
    <!-- Sender Party (Buyer — sends Invoice Response) -->
    <cac:SenderParty>
        <cac:PartyIdentification>
            <!-- SIREN identifier (scheme 0002) -->
            <cbc:ID schemeID="0002">123456789</cbc:ID>
        </cac:PartyIdentification>
        <cac:PartyLegalEntity>
            <cbc:RegistrationName>Entreprise Client France SA</cbc:RegistrationName>
        </cac:PartyLegalEntity>
    </cac:SenderParty>
    <!-- Receiver Party (Seller — receives Invoice Response) -->
    <cac:ReceiverParty>
        <cac:PartyIdentification>
            <!-- SIREN identifier (scheme 0002) -->
            <cbc:ID schemeID="0002">987654321</cbc:ID>
        </cac:PartyIdentification>
        <cac:PartyLegalEntity>
            <cbc:RegistrationName>TechDistrib France SARL</cbc:RegistrationName>
        </cac:PartyLegalEntity>
    </cac:ReceiverParty>
    <!-- Document Response -->
    <cac:DocumentResponse>
        <cac:Response>
            <ext:UBLExtensions>
                <ext:UBLExtension>
                    <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:ResponseExtension</ext:ExtensionURI>
                    <ext:ExtensionContent>
                        <puf:PageroExtension>
                            <puf:ResponseExtension>
                                <!-- DocumentMatchingID links this response to the original transaction -->
                                <puf:DocumentMatchingID>
                                    <cbc:ID>10000000007</cbc:ID>
                                </puf:DocumentMatchingID>
                            </puf:ResponseExtension>
                        </puf:PageroExtension>
                    </ext:ExtensionContent>
                </ext:UBLExtension>
            </ext:UBLExtensions>
            <!-- Response Code: UQ = Under Query (French code 207, En litige) -->
            <cbc:ResponseCode>UQ</cbc:ResponseCode>
            <!--
                Status 1 — Reason code + the data clarifications.
                listID="OPStatusReason" identifies this as a reason code status.
                TX_TVA_ERR = incorrect VAT rate. Valid for response code UQ (207) per the CDV schematron.
                The puf:Clarifications describe the disputed field: BT-152 (line VAT rate) with the
                current/invalid value (DIV = 10%) and the expected/valid value (DVA = 20%).
            -->
            <cac:Status>
                <ext:UBLExtensions>
                    <ext:UBLExtension>
                        <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:StatusExtension</ext:ExtensionURI>
                        <ext:ExtensionContent>
                            <puf:PageroExtension>
                                <puf:StatusExtension>
                                    <puf:Clarifications>
                                        <puf:Clarification>
                                            <puf:Code>BT-152</puf:Code>
                                            <puf:TypeCode>DIV</puf:TypeCode>
                                            <puf:Name>Taux TVA</puf:Name>
                                            <puf:Location>/Invoice/cac:InvoiceLine/cac:Item/cac:ClassifiedTaxCategory/cbc:Percent</puf:Location>
                                            <puf:ChangedIndicator>true</puf:ChangedIndicator>
                                            <puf:ValuePercent>10.00</puf:ValuePercent>
                                        </puf:Clarification>
                                        <puf:Clarification>
                                            <puf:Code>BT-152</puf:Code>
                                            <puf:TypeCode>DVA</puf:TypeCode>
                                            <puf:Name>Taux TVA</puf:Name>
                                            <puf:Location>/Invoice/cac:InvoiceLine/cac:Item/cac:ClassifiedTaxCategory/cbc:Percent</puf:Location>
                                            <puf:ChangedIndicator>true</puf:ChangedIndicator>
                                            <puf:ValuePercent>20.00</puf:ValuePercent>
                                        </puf:Clarification>
                                    </puf:Clarifications>
                                </puf:StatusExtension>
                            </puf:PageroExtension>
                        </ext:ExtensionContent>
                    </ext:UBLExtension>
                </ext:UBLExtensions>
                <cbc:StatusReasonCode listID="OPStatusReason">TX_TVA_ERR</cbc:StatusReasonCode>
                <cbc:StatusReason>Taux de TVA erroné (10 % appliqué au lieu de 20 %).</cbc:StatusReason>
            </cac:Status>
            <!--
                Status 2 — Requested action (what the seller should do).
                listID="OPStatusAction" identifies this as an action code status.
                CNF = create a full credit note.
            -->
            <cac:Status>
                <cbc:StatusReasonCode listID="OPStatusAction">CNF</cbc:StatusReasonCode>
                <cbc:StatusReason>Créer un Avoir total.</cbc:StatusReason>
            </cac:Status>
        </cac:Response>
        <!-- Reference to the original invoice -->
        <cac:DocumentReference>
            <cbc:ID>FR-INV-2026-001</cbc:ID>
            <cbc:IssueDate>2026-02-01</cbc:IssueDate>
            <!-- Document type code: 380 = Invoice -->
            <cbc:DocumentTypeCode>380</cbc:DocumentTypeCode>
        </cac:DocumentReference>
    </cac:DocumentResponse>
</ApplicationResponse>
