<?xml version="1.0" encoding="UTF-8"?>
<!--
    PUF Document Status — France
    Use Case: UC34 — Partial Payment Received (Encaissée partielle)

    Use Case Context:
    A buyer makes an initial partial payment on an invoice, with the remaining balance
    expected in a subsequent payment. The seller reports to the tax authority only the
    amount actually received (MEN), and indicates the remaining amount outstanding (RAP).

    Each partial payment must be declared separately to the tax authority (PPF) via
    a distinct PAYMENT_RECEIVED (code 212) Document Status.

    Sender  (Seller): TechDistrib France SARL — SIREN 987654321
    Receiver (Buyer): Entreprise Client France SA — SIREN 123456789

    Reference invoice: FR-UC34-INV-2026-001
      - EUR 1,000.00 HT + EUR 200.00 VAT @ 20% = EUR 1,200.00 TTC
      - BT-23 = S1 (standard services invoice)

    FIRST partial payment scenario:
      - Buyer pays EUR 600.00 TTC on 15/02/2026 (50% of invoice)
      - Remaining EUR 600.00 TTC is still outstanding
      - MEN = EUR 600.00 @ 20% VAT rate (actually received)
      - RAP = EUR 600.00 @ 20% VAT rate (remaining to pay)

    VAT PRE-FILLING NOTE:
    The tax authority pre-fills only the MEN amount (EUR 600 TTC) for this billing period.
    The remaining RAP (EUR 600 TTC) will be picked up in a subsequent Encaissée when paid.

    A SECOND Document Status must be sent when the remaining EUR 600 is received.
    If the balance is never paid (e.g., debt written off), the seller may need to
    issue a credit note for the outstanding amount.

    Reference: XP Z12-014 Annexe A, Section 3.2.33 (Cas n°34), V1.3
-->
<ApplicationResponse xmlns="urn:oasis:names:specification:ubl:schema:xsd:ApplicationResponse-2"
                     xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
                     xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2"
                     xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
                     xmlns:puf="urn:pagero:ExtensionComponent:1.0">
    <!-- Specification Identifier -->
    <cbc:CustomizationID>urn:pagero.com:puf:document_status:1.0</cbc:CustomizationID>
    <!-- Business process type identifier -->
    <cbc:ProfileID>urn:pagero.com:puf:document_status:1.0</cbc:ProfileID>
    <!-- Response identifier (max 20 characters) -->
    <cbc:ID>RESP-UC34-PART-001</cbc:ID>
    <!-- Response issue date -->
    <cbc:IssueDate>2026-02-16</cbc:IssueDate>
    <!-- Response issue time (mandatory in France) -->
    <cbc:IssueTime>09:15:00</cbc:IssueTime>
    <!-- Sender Party (Seller — reports partial collection) -->
    <cac:SenderParty>
        <cac:PartyIdentification>
            <cbc:ID schemeID="0002">987654321</cbc:ID>
        </cac:PartyIdentification>
        <cac:PartyLegalEntity>
            <cbc:RegistrationName>TechDistrib France SARL</cbc:RegistrationName>
        </cac:PartyLegalEntity>
    </cac:SenderParty>
    <!-- Receiver Party (Buyer — paid 50% of invoice) -->
    <cac:ReceiverParty>
        <cac:PartyIdentification>
            <cbc:ID schemeID="0002">123456789</cbc:ID>
        </cac:PartyIdentification>
        <cac:PartyLegalEntity>
            <cbc:RegistrationName>Entreprise Client France SA</cbc:RegistrationName>
        </cac:PartyLegalEntity>
    </cac:ReceiverParty>
    <!-- Document Response -->
    <cac:DocumentResponse>
        <cac:Response>
            <ext:UBLExtensions>
                <ext:UBLExtension>
                    <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:ResponseExtension</ext:ExtensionURI>
                    <ext:ExtensionContent>
                        <puf:PageroExtension>
                            <puf:ResponseExtension>
                                <puf:DocumentMatchingID>
                                    <cbc:ID>34000000001</cbc:ID>
                                </puf:DocumentMatchingID>
                            </puf:ResponseExtension>
                        </puf:PageroExtension>
                    </ext:ExtensionContent>
                </ext:UBLExtension>
            </ext:UBLExtensions>
            <!-- Response Code: PAYMENT_RECEIVED = Encaissée (French CDAR code 212) -->
            <cbc:ResponseCode>PAYMENT_RECEIVED</cbc:ResponseCode>
            <!--
                Status with MEN (amount received) and RAP (remaining to pay):

                Invoice: EUR 1,000 HT + EUR 200 VAT @ 20% = EUR 1,200 TTC
                First partial payment received: EUR 600 TTC (50%)
                Remaining balance: EUR 600 TTC (50%)

                MEN = EUR 600 TTC @ 20% (received on 15/02/2026)
                RAP = EUR 600 TTC @ 20% (outstanding balance)

                The tax authority uses MEN to pre-fill VAT return for this period.
                A second Encaissée for EUR 600 must follow when the balance is collected.
            -->
            <cac:Status>
                <ext:UBLExtensions>
                    <ext:UBLExtension>
                        <ext:ExtensionURI>urn:pagero:ExtensionComponent:1.0:PageroExtension:StatusExtension</ext:ExtensionURI>
                        <ext:ExtensionContent>
                            <puf:PageroExtension>
                                <puf:StatusExtension>
                                    <puf:Amounts>
                                        <!--
                                            MEN = Montant Encaissé (amount actually received).
                                            EUR 600 TTC @ 20% VAT = EUR 500 HT + EUR 100 VAT.
                                            This is the ONLY amount reported for VAT pre-filling
                                            in this billing period.
                                            Date = actual date of receipt (bank credit date).
                                        -->
                                        <puf:Amount>
                                            <puf:AmountType>MEN</puf:AmountType>
                                            <cbc:TaxExclusiveAmount currencyID="EUR">500.00</cbc:TaxExclusiveAmount>
                                            <cbc:TaxInclusiveAmount currencyID="EUR">600.00</cbc:TaxInclusiveAmount>
                                            <puf:ClassifiedTaxCategory>
                                                <cbc:Percent>20</cbc:Percent>
                                                <cac:TaxScheme>
                                                    <cbc:ID>VAT</cbc:ID>
                                                </cac:TaxScheme>
                                            </puf:ClassifiedTaxCategory>
                                            <puf:Date>2026-02-15</puf:Date>
                                        </puf:Amount>
                                        <!--
                                            RAP = Reste À Payer (remaining outstanding balance).
                                            EUR 600 TTC @ 20% VAT = balance after first partial payment.
                                            Informational: signals to tax authority that invoice is
                                            not fully paid. A second Encaissée must follow.
                                            No Date element on RAP (future payment, date unknown).
                                        -->
                                        <puf:Amount>
                                            <puf:AmountType>RAP</puf:AmountType>
                                            <cbc:TaxInclusiveAmount currencyID="EUR">600.00</cbc:TaxInclusiveAmount>
                                            <puf:ClassifiedTaxCategory>
                                                <cbc:Percent>20</cbc:Percent>
                                                <cac:TaxScheme>
                                                    <cbc:ID>VAT</cbc:ID>
                                                </cac:TaxScheme>
                                            </puf:ClassifiedTaxCategory>
                                        </puf:Amount>
                                    </puf:Amounts>
                                </puf:StatusExtension>
                            </puf:PageroExtension>
                        </ext:ExtensionContent>
                    </ext:UBLExtension>
                </ext:UBLExtensions>
                <!-- NON = no specific reason code; informational status -->
                <cbc:StatusReasonCode>NON</cbc:StatusReasonCode>
            </cac:Status>
        </cac:Response>
        <!-- Reference to the original invoice -->
        <cac:DocumentReference>
            <cbc:ID>FR-UC34-INV-2026-001</cbc:ID>
            <cbc:IssueDate>2026-02-01</cbc:IssueDate>
            <!-- Document type code: 380 = Invoice -->
            <cbc:DocumentTypeCode>380</cbc:DocumentTypeCode>
        </cac:DocumentReference>
    </cac:DocumentResponse>
</ApplicationResponse>
